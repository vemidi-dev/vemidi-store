# Optional for browsing the store: the app runs without these.
# Required for Supabase catalog, admin authentication, and checkout.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase secret key (recommended format: sb_secret_...).
# Legacy projects may use SUPABASE_SERVICE_ROLE_KEY instead.
# Never prefix either variable with NEXT_PUBLIC_ or expose it in browser code.
SUPABASE_SECRET_KEY=your-secret-key

# Optional dedicated Supabase project for integration tests (never production).
# Apply migrations #35 and #36 to this project before running npm run test:integration.
SUPABASE_TEST_URL=https://your-test-project-ref.supabase.co
SUPABASE_TEST_SECRET_KEY=your-test-secret-key

# Optional dedicated HMAC secret for checkout rate-limit fingerprints.
# If omitted, SUPABASE_SECRET_KEY is used. Generate a long random value.
CHECKOUT_RATE_LIMIT_SECRET=your-long-random-secret

# Production origin used in metadata, sitemap, and password recovery links.
NEXT_PUBLIC_SITE_URL=https://vemidi-crafts.com

# Required for Vercel Cron: /api/cron/retry-order-notifications (Bearer CRON_SECRET).
CRON_SECRET=your-long-random-secret

# Optional: transactional emails for new store orders (Resend).
# Without RESEND_API_KEY checkout still works; emails are skipped.
RESEND_API_KEY=re_your_resend_api_key
ORDER_NOTIFICATION_FROM=VeMiDi crafts <orders@your-verified-domain.com>
ORDER_NOTIFICATION_TO=vemidi.crafts@gmail.com

# Optional: Econt office/city lookup in checkout (same credentials as campaign landings).
ECONT_API_USERNAME=your-econt-api-username
ECONT_API_PASSWORD=your-econt-api-password
# Aliases also supported: ECONT_USERNAME / ECONT_PASSWORD / ECONT_USER / ECONT_PASS
