{
  "name": "lumaforge-store",
  "private": true,
  "scripts": {
    "clean": "node ./scripts/clean-next.mjs",
    "predev": "node ./scripts/ensure-dev-cache.mjs",
    "dev": "next dev",
    "dev:clean": "npm run clean && npm run dev",
    "dev:turbo": "next dev --turbo",
    "dev:webpack": "next dev",
    "build": "next build",
    "env:check": "node ./scripts/check-env.mjs",
    "supabase:check": "node ./scripts/supabase-smoke-check.mjs",
    "data:audit": "tsx scripts/data-audit.ts",
    "test:release": "node ./scripts/release-tests.mjs",
    "test:release:unit": "node ./scripts/release-tests.mjs --unit-only",
    "test:release:data": "npm run data:audit",
    "smoke:preview": "tsx scripts/smoke-preview.ts",
    "start": "next start",
    "test": "tsx --test tests/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.integration.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "0.34.5"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "1.2.4",
    "@img/sharp-linux-x64": "0.34.5",
    "@img/sharp-win32-x64": "0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@tailwindcss/postcss": "^4.0.17",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2"
  }
}
